{
  "name": "system-design-core",
  "image": "mcr.microsoft.com/devcontainers/java:17-bullseye",

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "redhat.vscode-yaml",
        "humao.rest-client"
      ]
    }
  },

  "forwardPorts": [8080, 8081, 8082, 8083, 8084],

  "postCreateCommand": "echo 'Dev container ready'"
}
